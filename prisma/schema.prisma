generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  nameFr    String
  nameEn    String
  order     Int       @default(0)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id            String          @id @default(cuid())
  slug          String          @unique
  code          String
  titleFr       String
  titleEn       String
  subtitleFr    String
  subtitleEn    String
  descriptionFr String          @db.Text
  descriptionEn String          @db.Text
  year          String
  client        String
  role          String
  accent        String          @default("75")
  published     Boolean         @default(true)
  featured      Boolean         @default(true)
  order         Int             @default(0)
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  images        ProjectImage[]
  credits       ProjectCredit[]
  sketchLabel   String?
  renderLabel   String?
  sketchUrl     String?
  renderUrl     String?
  thumbnailUrl  String?
  thumbnailX    Int             @default(50)
  thumbnailY    Int             @default(50)
  wipePosition  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([categoryId])
  @@index([published, featured])
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  ratio     String  @default("16/9")
  labelFr   String
  labelEn   String
  order     Int     @default(0)

  @@index([projectId])
}

model ProjectCredit {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleFr    String
  roleEn    String
  name      String
  order     Int     @default(0)

  @@index([projectId])
}

model About {
  id          String     @id @default(cuid())
  bioFr       String     @db.Text
  bioEn       String     @db.Text
  portraitUrl String?
  timeline    Timeline[]
  updatedAt   DateTime   @updatedAt
}

model Timeline {
  id      String @id @default(cuid())
  aboutId String
  about   About  @relation(fields: [aboutId], references: [id], onDelete: Cascade)
  period  String
  roleFr  String
  roleEn  String
  place   String
  order   Int    @default(0)

  @@index([aboutId])
}

model Setting {
  id                String   @id @default(cuid())
  logoUrl           String?
  siteTitleFr       String   @default("Khalil — Designer automobile")
  siteTitleEn       String   @default("Khalil — Automotive Designer")
  siteTaglineFr     String   @default("Concept, série, écran.")
  siteTaglineEn     String   @default("Concept, series, screen.")
  metaDescriptionFr String   @default("Portfolio de Khalil, designer automobile.")
  metaDescriptionEn String   @default("Portfolio of Khalil, automotive designer.")
  email             String   @default("contact@example.com")
  location          String   @default("Paris / Turin")
  socials           Json     @default("[]")

  bgLight           String   @default("#f4f3ef")
  fgLight           String   @default("#0a0a0a")
  mutedLight        String   @default("#737373")
  bgDark            String   @default("#050505")
  fgDark            String   @default("#f0eee8")
  mutedDark         String   @default("rgba(240,238,232,0.55)")
  accentL           Float    @default(0.78)
  accentC           Float    @default(0.17)
  accentH           Float    @default(75)

  fontDisplay       String   @default("Space Grotesk")
  fontMono          String   @default("JetBrains Mono")
  fontBody          String   @default("Inter")

  updatedAt         DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  body      String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
}
